<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="6dp"
    android:paddingEnd="8dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/stageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/age_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/age_text_muted"
        android:textSize="13sp" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:max="100" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:textColor="@color/age_text"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/indexStatsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/age_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/matchStatsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/age_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/safetyHintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="已完成的 Bangumi 查询会立即落盘；中途停止后，下次会直接复用已成功的查询，不会从头重来。"
        android:textColor="@color/age_text_muted"
        android:textSize="12sp" />

</LinearLayout>
