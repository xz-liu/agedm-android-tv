<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/age_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/pageHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/age_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pageSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/main_subtitle"
            android:textColor="@color/age_text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@color/age_line" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/navCastButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_cast"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_home"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navCatalogButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_catalog"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navRecommendButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_recommend"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navUpdateButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_update"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navRankButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_rank"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/navHistoryButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_history"
            android:textColor="@color/age_text"
            android:textSize="13sp" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/filterPrimaryButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_focusable_small"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/filterSecondaryButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_focusable_small"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/filterTertiaryButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_focusable_small"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/filterQuaternaryButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_focusable_small"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/filterFifthButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_focusable_small"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/filterResetButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_focusable_small"
                android:text="@string/btn_reset"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/contentStage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/castContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="true"
            android:nextFocusUp="@id/navCastButton"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- QR panel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/castQrImage"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:background="#FFFFFF"
                    android:contentDescription="@string/btn_cast"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/castErrorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_panel_soft"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/age_text_muted"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="手机扫码，搜索并投送到电视"
                    android:textColor="@color/age_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:background="#1b3549" />

            <!-- Mirror panel -->
            <LinearLayout
                android:id="@+id/castMirrorPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/mirrorQueryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待手机搜索..."
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"
                    android:background="#1b3549" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/mirrorRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingTop="8dp"
                        android:scrollbars="none"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/mirrorEmptyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="搜索结果会实时显示在这里"
                        android:textColor="@color/age_text_muted"
                        android:textSize="13sp" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/contentRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_panel_soft"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="18dp"
            android:paddingEnd="24dp"
            android:paddingBottom="18dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/loading_text"
                android:textColor="@color/age_text"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_panel_soft"
            android:paddingStart="22dp"
            android:paddingTop="14dp"
            android:paddingEnd="22dp"
            android:paddingBottom="14dp"
            android:text="@string/empty_text"
            android:textColor="@color/age_text_muted"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_margin="20dp"
            android:background="@drawable/bg_panel_soft"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:textColor="@color/age_text"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/paginationBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        android:visibility="gone">

        <Button
            android:id="@+id/prevPageButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_prev_page"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/age_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/nextPageButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_next_page"
            android:textColor="@color/age_text"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
