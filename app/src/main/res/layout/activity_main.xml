<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/age_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel_soft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusDown="@id/webView"
            android:text="@string/btn_back"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/homeButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusDown="@id/webView"
            android:text="@string/btn_home"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/castButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusDown="@id/webView"
            android:text="@string/btn_cast"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/continueButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusDown="@id/webView"
            android:text="@string/btn_continue"
            android:textColor="@color/age_text"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/webview_title"
                android:textColor="@color/age_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pageSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Web 浏览 + 原生播放器"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <TextView
            android:id="@+id/overlayMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_margin="20dp"
            android:background="@drawable/bg_panel_soft"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:textColor="@color/age_text"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_panel_soft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusUp="@id/webView"
            android:text="@string/btn_home"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/navCatalogButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusUp="@id/webView"
            android:text="@string/btn_catalog"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/navRecommendButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusUp="@id/webView"
            android:text="@string/btn_recommend"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/navUpdateButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusUp="@id/webView"
            android:text="@string/btn_update"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/navRankButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusUp="@id/webView"
            android:text="@string/btn_rank"
            android:textColor="@color/age_text" />
    </LinearLayout>

</LinearLayout>
