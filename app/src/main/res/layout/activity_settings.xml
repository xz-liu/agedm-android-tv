<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/age_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_focusable_small"
            android:nextFocusDown="@id/speedSettingButton"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/btn_back"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/age_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pageSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/settings_subtitle"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/age_line" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_playback"
                android:textColor="@color/age_focus"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/speedSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/backButton"
                android:nextFocusDown="@id/autoNextSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="默认倍速"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/speedValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/autoNextSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/speedSettingButton"
                android:nextFocusDown="@id/skipIntroSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动下一集"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/autoNextValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/skipIntroSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/autoNextSettingButton"
                android:nextFocusDown="@id/sourceOrderSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="跳过片头时长"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/skipIntroValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_section_source"
                android:textColor="@color/age_focus"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/sourceOrderSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/skipIntroSettingButton"
                android:nextFocusDown="@id/updateSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="外部源顺序"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/sourceOrderValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/sourceHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:text="@string/settings_source_hint"
                android:textColor="@color/age_text_muted"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Bangumi"
                android:textColor="@color/age_focus"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/bangumiLoginSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/sourceOrderSettingButton"
                android:nextFocusDown="@id/updateSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="登录 bgm.tv 账户"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/bangumiLoginValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/bangumiLoginHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/age_text_muted"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/settings_section_app"
                android:textColor="@color/age_focus"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/updateSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/bangumiLoginSettingButton"
                android:nextFocusDown="@id/clearCacheSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_update_button"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/updateHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:text="@string/settings_update_hint"
                android:textColor="@color/age_text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/clearCacheSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/updateSettingButton"
                android:nextFocusDown="@id/clearHistorySettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="清除缓存"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/cacheSizeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/clearHistorySettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_focusable_small"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:nextFocusUp="@id/clearCacheSettingButton"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="清除观看记录"
                    android:textColor="@color/age_text"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="@color/age_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
