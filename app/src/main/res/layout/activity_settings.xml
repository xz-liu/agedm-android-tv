<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/age_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel_soft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_back"
            android:textColor="@color/age_text"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/age_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pageSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_subtitle"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_playback"
                android:textColor="@color/age_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/speedSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_focusable_small"
                android:gravity="center_vertical|start"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/age_text"
                android:textSize="16sp" />

            <Button
                android:id="@+id/autoNextSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_focusable_small"
                android:gravity="center_vertical|start"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/age_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/settings_section_source"
                android:textColor="@color/age_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/sourceOrderSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_focusable_small"
                android:gravity="center_vertical|start"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/age_text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/sourceHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_source_hint"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/settings_section_app"
                android:textColor="@color/age_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/updateSettingButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_focusable_small"
                android:gravity="center_vertical|start"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/settings_update_button"
                android:textColor="@color/age_text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/updateHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_update_hint"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
