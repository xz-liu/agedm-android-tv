<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/age_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="28dp">

    <Button
        android:id="@+id/closeButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="start"
        android:background="@drawable/bg_focusable_small"
        android:text="@string/btn_back"
        android:textColor="@color/age_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="登录 Bangumi 账号"
        android:textColor="@color/age_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/accountStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/age_text_muted"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/qrImage"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="22dp"
        android:background="#FFFFFF"
        android:padding="14dp" />

    <TextView
        android:id="@+id/loggedInHintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="重新扫码可以切换账号"
        android:textColor="@color/age_focus"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/urlText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@color/age_text_muted"
        android:textSize="12sp" />
</LinearLayout>
