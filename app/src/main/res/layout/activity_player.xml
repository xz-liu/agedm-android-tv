<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_scrim"
        android:visibility="gone" />

    <!-- Title / top info: gradient from dark top to transparent -->
    <LinearLayout
        android:id="@+id/topInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_player_gradient_top"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:paddingBottom="52dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/playerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/age_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/playerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/age_text_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <!--
        Unified bottom overlay.
        Layout order (top → bottom inside panel):
          1. Progress row + control buttons   ← always visible when overlay is open
          2. episodeSection (GONE by default) ← revealed by DOWN key
          3. sourceSection  (GONE by default) ← revealed together with episodes
        When the panel is anchored to the bottom of the screen, pressing DOWN
        from the controls row naturally enters the episode/source rows.
    -->
    <LinearLayout
        android:id="@+id/bottomControlContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="20dp"
        android:paddingEnd="32dp"
        android:paddingBottom="28dp"
        android:visibility="gone">

        <!-- Progress row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/currentTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/age_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@+id/progressTimeBar"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:focusable="false"
                android:clickable="false" />

            <TextView
                android:id="@+id/durationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/age_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/playPauseButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_player_button"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/btn_play_pause"
                android:textColor="@color/age_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/speedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_player_button"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/btn_speed"
                android:textColor="@color/age_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/autoNextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_player_button"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/btn_auto_next"
                android:textColor="@color/age_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/sourceSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/age_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Episode section: shown when user presses DOWN from controls -->
        <LinearLayout
            android:id="@+id/episodeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="选集"
                android:textColor="@color/age_focus"
                android:textSize="11sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/episodeRecycler"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Source section: shown together with episodeSection -->
        <LinearLayout
            android:id="@+id/sourceSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="切换源"
                android:textColor="@color/age_focus"
                android:textSize="11sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sourceRecycler"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_panel_soft"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:text="正在加载..."
        android:textColor="@color/age_text"
        android:textSize="15sp" />

    <!-- Brief OSD for skip / action feedback -->
    <TextView
        android:id="@+id/skipOsdText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="36dp"
        android:background="@drawable/bg_panel_soft"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        android:textColor="@color/age_focus"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
