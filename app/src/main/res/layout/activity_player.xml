<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_scrim"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/topInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_panel_soft"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/playerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/age_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/playerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/age_text_muted"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomControlContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="24dp"
        android:background="@drawable/bg_panel_soft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/playPauseButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_play_pause"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/speedButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_speed"
            android:textColor="@color/age_text" />

        <Button
            android:id="@+id/autoNextButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_focusable_small"
            android:text="@string/btn_auto_next"
            android:textColor="@color/age_text" />

        <TextView
            android:id="@+id/sourceSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/age_text_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/episodeDrawer"
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/bg_panel"
        android:elevation="10dp"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="播放源"
            android:textColor="@color/age_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sourceRecycler"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="分集"
            android:textColor="@color/age_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/episodeRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1" />
    </LinearLayout>

    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_panel_soft"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:text="正在加载..."
        android:textColor="@color/age_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/playerHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_panel_soft"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:text="OK 显示控制，左右快进快退，Down 打开选集"
        android:textColor="@color/age_text_muted"
        android:textSize="13sp" />

</FrameLayout>

