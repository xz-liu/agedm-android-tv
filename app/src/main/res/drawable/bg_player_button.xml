<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#3A7C69" />
            <stroke
                android:width="2dp"
                android:color="#D6FFF4" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#AA12283E" />
            <stroke
                android:width="3dp"
                android:color="#D6FFF4" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7A0C1D2D" />
            <stroke
                android:width="1dp"
                android:color="#7F6ED9B8" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
